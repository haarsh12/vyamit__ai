# Production Environment Variables Template
# Copy this to .env and fill in your actual values

# Security
SECRET_KEY=your_secret_key_here_minimum_32_characters

# Database Configuration (Render PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database

# Hugging Face Configuration
HUGGINGFACE_API_TOKEN=hf_your_token_here

# AI Model Configuration
XAI_GROK_API_KEY=xai-your_key_here
GEMINI_API_KEY=AIzaSy_your_key_here

# Hybrid Service Configuration
VYAMIT_HYBRID_GROK=true

# Supabase Configuration
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# SMS Configuration
FAST2SMS_API_KEY=your_fast2sms_key_here

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid_here

# Application Configuration
API_V1_STR=/api/v1
PROJECT_NAME=SnapBill Backend
ENVIRONMENT=production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=https://your-frontend-domain.com,https://snapbill.app